    "_postman_id": "2c01817e-8294-427f-a994-1712f13f4e26",
    "name": "ISP Billing & Customer Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for authentication, users, KAM, customers, entitlements, invoices, payments, packages, utility, and analytics."
